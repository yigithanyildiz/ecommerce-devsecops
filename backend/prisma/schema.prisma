generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category{
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  products     Product[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product{
  id           String @id @default(uuid())
  name         String
  slug         String @unique
  description  String?
  price        Decimal @db.Decimal(10,2)
  stock        Int @default(0)
  imageUrl     String?
  isActive     Boolean @default(true)

  categoryId   String
  category Category @relation(fields: [categoryId],references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
